# ============================================================================
# Loom .env.example
# Copy to .env and fill in. .env is gitignored.
# Most settings can also be put in ~/.loom/config.yaml; env vars override.
# ============================================================================

# --- AI Providers (set at least one) -----------------------------------------
# Provider API keys. Loaded as fallback when ~/.loom/config.yaml does not have
# an `api_key` set for the provider. Onboarding writes the key you enter into
# config.yaml directly; these are useful for headless setups or CI.

# OpenAI — default provider. Used for chat (gpt-4o) and embeddings
# (text-embedding-3-small) unless overridden in config.yaml.
OPENAI_API_KEY=sk-...

# Anthropic — Claude chat models. No embedding support; pair with another
# provider for embeddings.
ANTHROPIC_API_KEY=sk-ant-...

# xAI — Grok chat models. No embedding support.
XAI_API_KEY=xai-...

# OpenRouter — single key, every model. Chat only — no embeddings; pair with
# OpenAI or Ollama for the embed provider.
OPENROUTER_API_KEY=sk-or-...

# Ollama runs locally and needs no API key. Set its `host` in
# ~/.loom/config.yaml under providers.ollama.host (default
# http://localhost:11434). There is no OLLAMA_HOST env var.

# --- Backend (LOOM_* settings) -----------------------------------------------
# All keys here are read by LoomSettings (backend/core/config.py) with the
# `LOOM_` prefix. Uncomment to override defaults.

# Root directory for all Loom data (config, vaults, index, logs).
# Default: ~/.loom
# LOOM_HOME=/Users/you/.loom

# Name of the active vault under $LOOM_HOME/vaults/.
# Default: default
# LOOM_ACTIVE_VAULT=default

# Default LLM provider when none is specified.
# One of: openai, anthropic, xai, openrouter, ollama
# Default: openai
# LOOM_DEFAULT_PROVIDER=openai

# Allowed CORS origins for the FastAPI server, as a JSON list.
# Default: ["http://localhost:5173"]
# LOOM_CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Host port docker-compose maps the app to (http://localhost:<LOOM_PORT>).
# Only read by compose for the port mapping — handy when something else
# (e.g. a local uvicorn dev server) already holds 8000. Default: 8000.
# LOOM_PORT=8787

# Optional shared secret for the API. Unset (default) leaves the API open —
# the supported localhost posture. When set, every /api request except the
# health/readiness probes must send it as `Authorization: Bearer <token>` or
# `X-Loom-Token: <token>`. A speed bump for exposed ports, not real auth.
# LOOM_API_TOKEN=change-me

# Allowed Host headers (DNS-rebinding defense), comma-separated. Only needed
# when serving Loom under a real hostname behind a reverse proxy.
# Default: localhost-style hosts only.
# LOOM_ALLOWED_HOSTS=loom.example.com,localhost

# --- Optional services (Redis cache + Postgres trace store) -------------------
# Both are opt-in: with neither set (or set empty), Loom behaves exactly as
# before. Under Docker they pair with `docker compose --profile full up`,
# which starts the bundled redis/postgres services — uncomment the two
# compose-network URLs below to wire them in. For non-Docker setups, point
# the same variables at your own Redis/Postgres instead.

# Redis URL for the LLM/embed response cache. Redis being down just degrades
# every lookup to a cache miss.
# LOOM_REDIS_URL=redis://redis:6379/0

# Postgres URL for the durable trace/run mirror (the in-memory ring and disk
# mirror keep working either way).
# LOOM_DATABASE_URL=postgresql://loom:loom@postgres:5432/loom

# Password for the compose-managed Postgres service (used in the
# LOOM_DATABASE_URL above when running `--profile full`). Default: loom.
# LOOM_PG_PASSWORD=loom

# Days of persisted traces/run summaries to keep — a daily sweep prunes both
# the disk mirror and the Postgres mirror. Negative disables pruning.
# LOOM_TRACE_RETENTION_DAYS=30

# --- Frontend (Vite) ---------------------------------------------------------
# Read by frontend/src/api/client.ts. Only takes effect at `npm run dev` /
# `npm run build` time — Vite inlines it. Must be prefixed VITE_ to be exposed.

# Base URL for the backend API. Default: http://localhost:8000
# VITE_API_BASE=http://localhost:8000

# --- Docker -----------------------------------------------------------------
# `docker compose up` builds the frontend with VITE_API_BASE="" (same-origin),
# sets LOOM_HOME=/data, and persists vaults in the `loom-data` volume — a
# single container. `docker compose --profile full up` adds the optional
# Redis/Postgres services (wire them via LOOM_REDIS_URL / LOOM_DATABASE_URL
# above). The only values worth putting in .env for Docker are the provider
# keys above — the remaining LOOM_* and VITE_* overrides here are for
# non-Docker / advanced setups.
